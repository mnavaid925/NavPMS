# Django Settings
SECRET_KEY=change-me-to-a-long-random-secret-in-production
DEBUG=True
ALLOWED_HOSTS=*

# Database (MySQL via XAMPP)
DB_ENGINE=django.db.backends.mysql
DB_NAME=navpms
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Application
APP_NAME=NavPMS
TIME_ZONE=UTC
LANGUAGE_CODE=en-us

# Login URLs
LOGIN_URL=/accounts/login/
LOGIN_REDIRECT_URL=/
LOGOUT_REDIRECT_URL=/accounts/login/

# Email (dev: console backend; production: configure SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@navpms.local

# Mock payment gateway (switch to 'stripe' or 'razorpay' later)
PAYMENT_GATEWAY=mock

# Module 12 — Order Fulfillment freight carrier connector (mock by default;
# real carriers wire in via apps/fulfillment/carriers.py). FREIGHT_TRACKING_ALLOWLIST
# is an optional comma-separated SSRF allowlist for a real carrier's tracking host.
FREIGHT_CARRIER=mock
FREIGHT_TRACKING_ALLOWLIST=
