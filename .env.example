# Django Settings
SECRET_KEY=change-me-to-a-long-random-secret-in-production
DEBUG=True
ALLOWED_HOSTS=*

# Database (MySQL via XAMPP)
DB_ENGINE=django.db.backends.mysql
DB_NAME=navpms
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# Application
APP_NAME=NavPMS
TIME_ZONE=UTC
LANGUAGE_CODE=en-us

# Login URLs
LOGIN_URL=/accounts/login/
LOGIN_REDIRECT_URL=/
LOGOUT_REDIRECT_URL=/accounts/login/

# Email (dev: console backend; production: configure SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@navpms.local

# Mock payment gateway (switch to 'stripe' or 'razorpay' later)
PAYMENT_GATEWAY=mock

# Module 12 — Order Fulfillment freight carrier connector (mock by default;
# real carriers wire in via apps/fulfillment/carriers.py). FREIGHT_TRACKING_ALLOWLIST
# is an optional comma-separated SSRF allowlist for a real carrier's tracking host.
FREIGHT_CARRIER=mock
FREIGHT_TRACKING_ALLOWLIST=

# Module 14 — Invoice & Voucher Management. OCR_ENGINE selects the invoice-capture
# connector (mock by default; real engines wire in via apps/invoicing/ocr.py). The two
# tolerances (percent) set how far an invoice line's quantity / unit price may drift from
# the PO + Goods Receipt before the three-way match flags a variance.
OCR_ENGINE=mock
INVOICE_QTY_TOLERANCE_PCT=2
INVOICE_PRICE_TOLERANCE_PCT=2
# OCR captures below this confidence (percent) are flagged "needs manual review" in the UI.
OCR_MIN_CONFIDENCE=70
# Days a dispute may stay open before an escalation alert fires.
INVOICE_DISPUTE_SLA_DAYS=5
# Opt-in: also email the invoice owner on overdue / closing-discount / dispute-SLA alerts
# (in addition to the in-app notification). Off by default; requires a real EMAIL_BACKEND.
INVOICE_EMAIL_ALERTS=False

# Module 18 — Risk & Compliance Management. SCREENING_PROVIDER / CREDIT_PROVIDER select the
# restricted-party screening + supplier credit-score connectors (mock by default; real providers
# wire in via apps/compliance/screening.py / credit.py). The *_ALLOWLIST values are optional
# comma-separated SSRF allowlists for a real provider's host. SCREENING_MATCH_THRESHOLD is the
# fuzzy-match percent for a hit; CREDIT_SCORE_DROP_ALERT the score drop that raises an alert; the
# FRAUD_* values tune the fraud detectors; POLICY_ACK_REMINDER_DAYS paces the cron ack reminders.
SCREENING_PROVIDER=mock
SCREENING_ALLOWLIST=
SCREENING_MATCH_THRESHOLD=85
CREDIT_PROVIDER=mock
CREDIT_ALLOWLIST=
CREDIT_SCORE_DROP_ALERT=10
FRAUD_SPLIT_PO_WINDOW_DAYS=14
FRAUD_ROUND_AMOUNT_FLOOR=5000
POLICY_ACK_REMINDER_DAYS=14

# Module 19 — Inventory & Warehouse Integration. INVENTORY_AUTO_REORDER toggles whether the cron
# (run_inventory_alerts) auto-generates draft requisitions for items at/below their reorder point.
# INVENTORY_EXPIRY_ALERT_DAYS is the look-ahead window (days) for the one-time near-expiry alert.
# INVENTORY_DEFAULT_WAREHOUSE_CODE is the warehouse auto-created to land received stock with no bin.
INVENTORY_AUTO_REORDER=True
INVENTORY_EXPIRY_ALERT_DAYS=30
INVENTORY_DEFAULT_WAREHOUSE_CODE=WH-MAIN

# Module 20 — Document & Knowledge Management. DMS_EXTRACTION_ENGINE selects the pluggable
# text-extraction engine that fills the searchable index field (mock by default = local, no
# dependency; `local` parses real PDFs via pypdf; hosted engines wire in via apps/dms/extraction.py).
# DMS_EXTRACTION_ALLOWLIST is an optional comma-separated SSRF allowlist for a real (remote) engine.
# DMS_MAX_INDEX_CHARS caps stored extracted text (chars); DMS_UPLOAD_MAX_MB caps upload size (MB).
DMS_EXTRACTION_ENGINE=mock
DMS_EXTRACTION_ALLOWLIST=
DMS_MAX_INDEX_CHARS=200000
DMS_UPLOAD_MAX_MB=10

# Module 21 — System Administration & Security. Each integration is a pluggable connector that is
# mock by default (zero external deps; real backends wire in via apps/sysadmin/connectors.py /
# backups.py / webhooks.py). SSO_METADATA_ALLOWLIST / WEBHOOK_SSRF_ALLOWLIST are comma-separated
# SSRF allowlists of extra hosts a real SSO-metadata or webhook target may reach (else HTTPS +
# public-host only, fail-closed). WEBHOOK_MAX_ATTEMPTS caps webhook retries; WEBHOOK_TIMEOUT_SECONDS
# bounds each delivery; API_KEY_PREFIX brands issued API keys; BACKUP_RETENTION_DEFAULT_DAYS is the
# default retention a new backup policy starts with.
SSO_CONNECTOR=mock
SSO_METADATA_ALLOWLIST=
BACKUP_CONNECTOR=mock
BACKUP_RETENTION_DEFAULT_DAYS=30
WEBHOOK_SSRF_ALLOWLIST=
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_TIMEOUT_SECONDS=10
API_KEY_PREFIX=pms
